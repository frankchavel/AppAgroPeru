<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#FDFBF7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════
             HEADER VERDE
        ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_green_rounded"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#FFFFFF"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MI CAMPO"
                        android:textColor="#C8E6C9"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registrar Cultivo"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ingresa los datos de tu nuevo cultivo"
                android:textColor="#C8E6C9"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- ══════════════════════════════════════
             FORMULARIO
        ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── SECCIÓN: Información básica ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN BÁSICA"
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Nombre del cultivo -->
            <TextView style="@style/LabelField" android:text="Nombre del cultivo *" />
            <EditText
                android:id="@+id/et_nombre_cultivo"
                style="@style/InputField"
                android:hint="Ej: Maíz Amarillo"
                android:inputType="textCapWords" />

            <!-- Descripción -->
            <TextView
                style="@style/LabelField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del cultivo *" />

            <EditText
                android:id="@+id/et_descripcion"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_white_rounded_border"
                android:hint="Describe tu cultivo..."
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:gravity="top"
                android:textColorHint="#9E9E9E"
                android:textColor="#0C1324"
                android:textSize="15sp"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp" />

            <!-- ── SECCIÓN: Ubicación ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F4F0"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UBICACIÓN"
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Botón seleccionar zona del mapa -->
            <TextView style="@style/LabelField" android:text="Zona agrícola *" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Zona seleccionada (preview) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#2E7D32" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/tv_zona_nombre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin zona seleccionada"
                                android:textColor="#0C1324"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_zona_coords"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Toca el botón para seleccionar"
                                android:textColor="#78909C"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Botón ir al mapa -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_seleccionar_zona"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Seleccionar zona en el mapa"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_menu_mapmode"
                        app:iconSize="18dp"
                        app:iconTint="#2E7D32"
                        app:strokeColor="#2E7D32"
                        tools:ignore="TouchTargetSizeCheck" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── SECCIÓN: Medidas ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F4F0"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATOS DE PRODUCCIÓN"
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Área + Tiempo de riego -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView style="@style/LabelField" android:text="Área (hectáreas) *" />
                    <EditText
                        android:id="@+id/et_area"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_white_rounded_border"
                        android:hint="Ej: 2.5"
                        android:paddingHorizontal="16dp"
                        android:textColorHint="#9E9E9E"
                        android:textColor="#0C1324"
                        android:textSize="15sp"
                        android:inputType="numberDecimal" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView style="@style/LabelField" android:text="Riego (hrs/día)" />
                    <EditText
                        android:id="@+id/et_riego"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_white_rounded_border"
                        android:hint="Ej: 2"
                        android:paddingHorizontal="16dp"
                        android:textColorHint="#9E9E9E"
                        android:textColor="#0C1324"
                        android:textSize="15sp"
                        android:inputType="numberDecimal" />

                </LinearLayout>

            </LinearLayout>

            <!-- Fechas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView style="@style/LabelField" android:text="Fecha de siembra *" />
                    <TextView
                        android:id="@+id/tv_fecha_siembra"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_white_rounded_border"
                        android:drawableStart="@android:drawable/ic_menu_my_calendar"
                        android:drawableTint="#78909C"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:hint="dd/mm/aaaa"
                        android:paddingHorizontal="12dp"
                        android:textColor="#0C1324"
                        android:textColorHint="#9E9E9E"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView style="@style/LabelField" android:text="Cosecha estimada" />
                    <TextView
                        android:id="@+id/tv_fecha_cosecha"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_white_rounded_border"
                        android:drawableStart="@android:drawable/ic_menu_my_calendar"
                        android:drawableTint="#78909C"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:hint="dd/mm/aaaa"
                        android:paddingHorizontal="12dp"
                        android:textColor="#0C1324"
                        android:textColorHint="#9E9E9E"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- Estado del cultivo -->
            <TextView style="@style/LabelField" android:text="Estado del cultivo" />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_estado"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#E0E0E0"
                app:boxBackgroundColor="#FFFFFF"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/actv_estado"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:focusable="false"
                    android:hint="Seleccionar estado"
                    android:inputType="none"
                    android:paddingHorizontal="16dp"
                    android:textColor="#0C1324"
                    android:textColorHint="#9E9E9E"
                    android:textSize="15sp"
                    tools:ignore="SpeakableTextPresentCheck" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── SECCIÓN: Insumos / Productos ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F4F0"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INSUMOS Y PRODUCTOS"
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Card insumo seleccionado -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_eco"
                            app:tint="#2E7D32" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/tv_insumo_nombre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin insumo seleccionado"
                                android:textColor="#0C1324"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_insumo_detalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Selecciona fertilizantes, semillas u otros"
                                android:textColor="#78909C"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Botón seleccionar insumo -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_seleccionar_insumo"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Seleccionar insumos / productos"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#2E7D32"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_eco"
                        app:iconTint="#2E7D32"
                        app:iconSize="18dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- recursoD (descripción libre de recurso) -->
            <TextView style="@style/LabelField" android:text="Recurso / observación" />
            <EditText
                android:id="@+id/et_recurso_d"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_white_rounded_border"
                android:hint="Ej: Semilla certificada INIA"
                android:paddingHorizontal="16dp"
                android:textColorHint="#9E9E9E"
                android:textColor="#0C1324"
                android:textSize="15sp"
                android:inputType="textCapSentences"
                android:layout_marginBottom="28dp" />

            <!-- ── Botón Guardar ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_guardar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Guardar Cultivo"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_eco"
                app:iconTint="#FFFFFF"
                app:iconSize="20dp"
                app:iconGravity="textStart" />
            <!-- ── Botón Guardar ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lista"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="Lista"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_eco"
                app:iconTint="#FFFFFF"
                app:iconSize="20dp"
                app:iconGravity="textStart" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>