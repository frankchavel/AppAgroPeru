<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F1"
    tools:context=".ActivityRecurso">

    <!-- Header verde oscuro -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#1B3A20"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_white_rounded_border"
                android:backgroundTint="#2E5C35"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Nuevo Insumo"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_border"
                android:backgroundTint="#39FF14"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="INSUMO"
                android:textColor="#1B3A20"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Completa los datos del insumo agrícola"
            android:textColor="#8DB898"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ScrollView con el formulario -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-32dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="32dp">

                    <!-- ── NOMBRE DEL INSUMO ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@android:drawable/ic_menu_edit"
                        android:drawablePadding="6dp"
                        android:drawableTint="#39FF14"
                        android:text="Nombre del Insumo"
                        android:textColor="#2E4D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxBackgroundColor="#F7FAF7"
                        app:boxStrokeColor="#C8DFC9"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#5A8060">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_nombre_insumo"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@android:color/transparent"
                            android:hint="Ej: Fertilizante NPK"
                            android:inputType="textCapSentences"
                            android:textColor="#1A2E1C"
                            android:textColorHint="#AABFAC"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── TIPO DE INSUMO ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@android:drawable/ic_menu_sort_by_size"
                        android:drawablePadding="6dp"
                        android:drawableTint="#39FF14"
                        android:text="Tipo de Insumo"
                        android:textColor="#2E4D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxBackgroundColor="#F7FAF7"
                        app:boxStrokeColor="#C8DFC9"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#5A8060">

                        <AutoCompleteTextView
                            android:id="@+id/et_tipo_insumo"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@android:color/transparent"
                            android:hint="Selecciona el tipo"
                            android:inputType="none"
                            android:textColor="#1A2E1C"
                            android:textColorHint="#AABFAC"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── FILA: UNIDAD + PRECIO ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <!-- Unidad de Medida -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableStart="@android:drawable/ic_menu_agenda"
                                android:drawablePadding="6dp"
                                android:drawableTint="#39FF14"
                                android:text="Unidad de Medida"
                                android:textColor="#2E4D32"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.03" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="20dp"
                                app:boxCornerRadiusBottomEnd="14dp"
                                app:boxCornerRadiusBottomStart="14dp"
                                app:boxCornerRadiusTopEnd="14dp"
                                app:boxCornerRadiusTopStart="14dp"
                                app:boxBackgroundColor="#F7FAF7"
                                app:boxStrokeColor="#C8DFC9"
                                app:boxStrokeWidth="1.5dp"
                                app:hintTextColor="#5A8060">

                                <AutoCompleteTextView
                                    android:id="@+id/et_unidad_medida"
                                    android:layout_width="match_parent"
                                    android:layout_height="56dp"
                                    android:background="@android:color/transparent"
                                    android:hint="Kg, L, Unid..."
                                    android:inputType="none"
                                    android:textColor="#1A2E1C"
                                    android:textColorHint="#AABFAC"
                                    android:textSize="15sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Precio Establecido -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableStart="@android:drawable/ic_menu_mylocation"
                                android:drawablePadding="6dp"
                                android:drawableTint="#39FF14"
                                android:text="Precio (S/)"
                                android:textColor="#2E4D32"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.03" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="20dp"
                                app:boxCornerRadiusBottomEnd="14dp"
                                app:boxCornerRadiusBottomStart="14dp"
                                app:boxCornerRadiusTopEnd="14dp"
                                app:boxCornerRadiusTopStart="14dp"
                                app:boxBackgroundColor="#F7FAF7"
                                app:boxStrokeColor="#C8DFC9"
                                app:boxStrokeWidth="1.5dp"
                                app:prefixText="S/ "
                                app:prefixTextColor="#39FF14"
                                app:hintTextColor="#5A8060">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_precio"
                                    android:layout_width="match_parent"
                                    android:layout_height="56dp"
                                    android:background="@android:color/transparent"
                                    android:hint="0.00"
                                    android:inputType="numberDecimal"
                                    android:textColor="#1A2E1C"
                                    android:textColorHint="#AABFAC"
                                    android:textSize="15sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ── FECHA DE REGISTRO ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@android:drawable/ic_menu_my_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#39FF14"
                        android:text="Fecha de Registro"
                        android:textColor="#2E4D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="32dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxBackgroundColor="#F7FAF7"
                        app:boxStrokeColor="#C8DFC9"
                        app:boxStrokeWidth="1.5dp"
                        app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                        app:endIconTint="#39FF14"
                        app:hintTextColor="#5A8060">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_fecha_registro"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@android:color/transparent"
                            android:hint="dd/mm/aaaa"
                            android:inputType="none"
                            android:focusable="false"
                            android:textColor="#1A2E1C"
                            android:textColorHint="#AABFAC"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="24dp"
                        android:background="#EAF2EB" />

                    <!-- Botón GUARDAR -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_guardar"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:text="GUARDAR INSUMO"
                        android:textColor="#1B3A20"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        app:backgroundTint="#39FF14"
                        app:cornerRadius="16dp"
                        app:elevation="0dp"
                        app:icon="@android:drawable/ic_menu_save"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        app:iconTint="#1B3A20" />

                    <!-- Botón CANCELAR -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cancelar"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Cancelar"
                        android:textColor="#5A8060"
                        android:textSize="15sp"
                        app:cornerRadius="16dp"
                        app:strokeColor="#C8DFC9"
                        app:strokeWidth="1.5dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>