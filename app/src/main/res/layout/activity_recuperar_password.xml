<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RecuperarPasswordActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#0C1324"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recuperar Contraseña"
            android:textColor="#0C1324"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/iv_header_planta"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:src="@drawable/planta_password"
        android:scaleType="centerCrop"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/top_bar"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/iv_header_planta"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Olvidaste tu contraseña?"
            android:textColor="#0C1324"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_subtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ingresa tu correo o número de celular para enviarte un código de recuperación."
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo" />

        <TextView
            android:id="@+id/lbl_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Celular o Correo"
            android:textColor="#546E7A"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitulo" />

        <EditText
            android:id="@+id/et_correo_celular"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_white_rounded_border"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="12dp"
            android:hint="ejemplo@correo.com o 999 999 999"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:textColorHint="#B0BEC5"
            app:layout_constraintTop_toBottomOf="@id/lbl_input" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_enviar_codigo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Enviar Código"
            android:textColor="#0C1324"
            android:textStyle="bold"
            app:backgroundTint="#39FF14"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="#0C1324"
            app:iconGravity="textEnd"
            app:layout_constraintTop_toBottomOf="@id/et_correo_celular" />

        <TextView
            android:id="@+id/btn_volver_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volver al inicio de sesión"
            android:gravity="center_vertical"
            android:textColor="#46A035"
            android:textSize="14sp"
            android:textStyle="bold"
            android:drawableStart="@android:drawable/ic_menu_revert"
            android:drawableTint="#46A035"
            android:drawablePadding="8dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>