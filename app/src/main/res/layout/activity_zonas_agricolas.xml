<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F0"
    tools:context=".ZonasAgricolasActivity">

    <!-- APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        android:background="#F0F7F0">

        <!-- Toolbar con mismo estilo que el header del mapa -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/verdeFosforecente">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp">

                <!-- Botón Back -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#2E7D32"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/btn_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_media_previous"
                        android:padding="10dp"
                        app:tint="#FFFFFF"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Título + subtítulo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zonas Agrícolas"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gestiona tus parcelas registradas"
                        android:textColor="@color/verdeOscuro"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Badge contador -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#2E7D32"
                    app:strokeColor="#69F0AE"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:id="@+id/tvContadorZonas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 zonas"
                        android:textColor="#69F0AE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buscador -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBuscador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:hint="Buscar zona..."
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxStrokeColor="#4CAF50"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#81C784"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="#4CAF50">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscador"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:textColor="#1B5E20"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- LISTA DE ZONAS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerZonas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="12dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- ESTADO VACÍO -->
    <LinearLayout
        android:id="@+id/layoutVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#E8F5E9"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_mapmode"
                android:padding="20dp"
                app:tint="#A5D6A7"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin zonas registradas"
            android:textColor="#1B5E20"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registra tu primera zona agrícola\ndesde el mapa"
            android:textColor="#78909C"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <!-- FAB Nueva Zona -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAgregarZona"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Nueva Zona"
        android:textColor="#1B5E20"
        android:textStyle="bold"
        android:textSize="13sp"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="#1B5E20"
        app:backgroundTint="@color/verdeFosforecente"
        app:elevation="10dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>