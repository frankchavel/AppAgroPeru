<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFBF7">

    <!-- HEADER VERDE -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_green_rounded"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINAGRI · SEPA"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tv_titulo_precios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Precios de Mercado"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Precios mayoristas actualizados en tiempo real"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Búsqueda dentro del header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_white_rounded_border"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#78909C" />

            <EditText
                android:id="@+id/et_buscar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="Buscar producto (ej. Papa, Limón)..."
                android:textColorHint="#9E9E9E"
                android:textColor="#0C1324"
                android:textSize="14sp"
                android:paddingStart="10dp"
                android:inputType="text"
                android:imeOptions="actionSearch" />

        </LinearLayout>

    </LinearLayout>

    <!-- FILTROS -->
    <LinearLayout
        android:id="@+id/section_filtros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:id="@+id/tv_mercado_selector"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_white_rounded_border"
            android:drawableStart="@android:drawable/ic_menu_mylocation"
            android:drawableEnd="@android:drawable/arrow_down_float"
            android:drawablePadding="8dp"
            android:drawableTint="#2E7D32"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Gran Mercado Mayorista de Lima"
            android:textColor="#0C1324"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_ultima_act"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Última actualización: Hoy, 05:45 AM"
                android:textColor="#78909C"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● EN VIVO"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Chips con IDs para poder referenciarlos en Java -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_filtro_todos"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Todos"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    app:backgroundTint="@color/verde"
                    app:cornerRadius="20dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_filtro_tuberculos"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Tubérculos"
                    android:textColor="#546E7A"
                    android:textSize="13sp"
                    app:strokeColor="#E0E0E0"
                    app:cornerRadius="20dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_filtro_hortalizas"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Hortalizas"
                    android:textColor="#546E7A"
                    android:textSize="13sp"
                    app:strokeColor="#E0E0E0"
                    app:cornerRadius="20dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_filtro_frutas"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Frutas"
                    android:textColor="#546E7A"
                    android:textSize="13sp"
                    app:strokeColor="#E0E0E0"
                    app:cornerRadius="20dp" />

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_precios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/section_filtros"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="0dp"
        tools:listitem="@layout/item_precio_mercado" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:itemIconTint="@color/bottom_nav_color_selector"
        app:itemTextColor="@color/bottom_nav_color_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>