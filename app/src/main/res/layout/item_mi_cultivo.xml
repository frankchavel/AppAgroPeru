<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nombre + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_nombre_lote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Papa Amarilla"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0C1324"/>

            <TextView
                android:id="@+id/tv_estado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_tag_activo"/>
        </LinearLayout>

        <!-- Info rápida -->
        <TextView
            android:id="@+id/tv_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Área: 2.5 ha | Zona: Cajamarca"
            android:textSize="12sp"
            android:textColor="#546E7A"
            android:layout_marginTop="6dp"/>

        <!-- Progreso -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/pb_progreso"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="10dp"
            android:progress="50"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp"
            app:indicatorColor="#2E7D32"/>

        <TextView
            android:id="@+id/tv_progreso_dias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Día 45 de 90"
            android:textSize="11sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="4dp"/>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_detalles"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Ver detalles"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#2E7D32"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_asignar_insumo"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Asignar Insumo"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#39FF14"
                android:textColor="#0C1324"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>