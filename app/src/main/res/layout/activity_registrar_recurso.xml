<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2F5F0"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Card (estilo hero como en la imagen) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#2E7D32"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="28dp">

                    <!-- Icono + subtítulo -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="🌿"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MI CAMPO"
                                android:textColor="#A5D6A7"
                                android:textSize="10sp"
                                android:letterSpacing="0.15"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registrar Insumo"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agrega un nuevo insumo a tu inventario"
                        android:textSize="13sp"
                        android:textColor="#C8E6C9"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Contenido del formulario -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Sección: Información del insumo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información del insumo"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp"
                    android:layout_marginTop="4dp"/>

                <!-- Card con campos agrupados -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Nombre del insumo -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nombre del insumo"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#4CAF50"
                            app:hintTextColor="#2E7D32"
                            app:startIconDrawable="@android:drawable/ic_menu_edit"
                            app:startIconTint="#66BB6A">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#1B2E1C"
                                android:inputType="textCapWords"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Tipo -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tipo (Fertilizante, Herbicida...)"
                            android:layout_marginTop="14dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#4CAF50"
                            app:hintTextColor="#2E7D32"
                            app:startIconDrawable="@android:drawable/ic_menu_agenda"
                            app:startIconTint="#66BB6A">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_tipo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#1B2E1C"
                                android:inputType="textCapSentences"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sección: Detalles de uso -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detalles de uso"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp"/>

                <!-- Card con unidad y precio -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Unidad -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Unidad (Kg, Litros...)"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#4CAF50"
                            app:hintTextColor="#2E7D32"
                            app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                            app:startIconTint="#66BB6A">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_unidad"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#1B2E1C"
                                android:inputType="textCapWords"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Precio -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Precio unitario"
                            android:layout_marginTop="14dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#4CAF50"
                            app:hintTextColor="#2E7D32"
                            app:prefixText="S/ "
                            app:prefixTextColor="#388E3C"
                            app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                            app:startIconTint="#66BB6A">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_precio"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#1B2E1C"
                                android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Botón Guardar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guardar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Guardar Insumo"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:letterSpacing="0.05"
                    app:backgroundTint="#2E7D32"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_save"
                    app:iconTint="#FFFFFF"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Botón Cancelar secundario -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancelar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Cancelar"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#2E7D32"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="16dp"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</layout>