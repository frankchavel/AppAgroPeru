<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C1A0E">

    <!-- MAPA OCUPA TODA LA PANTALLA -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- OVERLAY SUPERIOR: Barra de título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingHorizontal="16dp">

        <!-- Header con fondo semitransparente -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#CC0C1A0E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:padding="4dp"
                    app:tint="#39FF14"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Registrar Zona Agrícola"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_ubicacion_actual"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Mi ubicación"
                    android:textColor="#0C1A0E"
                    android:textSize="11sp"
                    app:chipBackgroundColor="#39FF14"
                    app:chipIcon="@android:drawable/ic_menu_mylocation"
                    app:chipIconSize="14dp"
                    app:chipIconTint="#0C1A0E"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- BOTÓN FLOTANTE: Usar ubicación actual -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="380dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="#39FF14"
        app:elevation="8dp"
        app:fabSize="normal"
        app:tint="#0C1A0E"
        tools:ignore="SpeakableTextPresentCheck" />

    <!-- BOTTOM SHEET: Formulario de registro -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_sheet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#F5F7F5">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="420dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="24dp"
                android:paddingTop="12dp">

                <!-- Handle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="#CFD8DC"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"/>

                <!-- Título del formulario -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="28dp"
                        android:background="#39FF14"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Datos del Terreno"
                            android:textColor="#0C1A0E"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toca el mapa para fijar la ubicación"
                            android:textColor="#78909C"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Indicador de pin en mapa -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_coords_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="#E8F5E9">
                        <TextView
                            android:id="@+id/tv_coords_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sin ubicación"
                            android:textColor="#388E3C"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Campo: Nombre de Zona -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nombre_zona"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Nombre de la Zona"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxStrokeColor="#39FF14"
                    app:hintTextColor="#388E3C"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_menu_mapmode"
                    app:startIconTint="#39FF14">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre_zona"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:textColor="#0C1A0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Descripción -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_descripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Descripción del terreno"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxStrokeColor="#39FF14"
                    app:hintTextColor="#388E3C"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="#39FF14">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_descripcion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:maxLines="3"
                        android:textColor="#0C1A0E"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Coordenadas (auto-llenado desde mapa) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COORDENADAS (desde el mapa)"
                    android:textColor="#78909C"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Latitud -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_latitud"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="Latitud"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxBackgroundColor="#E8F5E9"
                        app:boxStrokeColor="#A5D6A7"
                        app:hintTextColor="#388E3C"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_latitud"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned"
                            android:textColor="#0C1A0E"
                            android:focusable="false"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Longitud -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_longitud"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="Longitud"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxBackgroundColor="#E8F5E9"
                        app:boxStrokeColor="#A5D6A7"
                        app:hintTextColor="#388E3C"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_longitud"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned"
                            android:textColor="#0C1A0E"
                            android:focusable="false"
                            />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Botón Guardar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guardar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Registrar Zona Agrícola"
                    android:textColor="#0C1A0E"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    app:backgroundTint="#39FF14"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_menu_save"
                    app:iconTint="#0C1A0E"
                    app:iconGravity="textStart"
                    app:elevation="4dp"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>