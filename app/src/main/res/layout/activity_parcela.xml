<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- BIENVENIDO DE NUEVO -->
                <TextView
                    android:id="@+id/tv_bienvenida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BIENVENIDO DE NUEVO"
                    android:textColor="#78909C"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Hola, Manuel + Avatar -->
                <TextView
                    android:id="@+id/tv_usuario_nombre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hola, Manuel"
                    android:textColor="#1B5E20"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/cv_perfil"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_bienvenida"
                    tools:text="Hola, Manuel" />

                <!-- Avatar perfil -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_perfil"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#2E7D32"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_usuario_nombre"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_usuario_nombre">

                    <ImageView
                        android:id="@+id/iv_mini_perfil"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#E0E0E0"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_outline" />
                </androidx.cardview.widget.CardView>

                <!-- Ubicación -->
                <TextView
                    android:id="@+id/tv_ubicacion_detalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:drawableStart="@android:drawable/ic_menu_mylocation"
                    android:drawablePadding="6dp"
                    android:drawableTint="#78909C"
                    android:paddingVertical="4dp"
                    android:text="Valle del Mantaro, Junín"
                    android:textColor="#546E7A"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_usuario_nombre"
                    tools:text="Valle del Mantaro, Junín" />

                <!-- ALERTA DE HELADA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_alerta_helada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#D32F2F"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_ubicacion_detalle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="#4DFFFFFF"
                                android:padding="4dp"
                                android:src="@android:drawable/ic_dialog_alert"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:id="@+id/tv_alerta_helada"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="¡ALERTA DE HELADA!"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_alerta_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Se prevé descenso de temperatura a -2°C esta madrugada. Proteja sus cultivos de papa."
                            android:textColor="#FFEBEE"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btn_ver_mapa"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="#B71C1C"
                            android:text="Ver Mapa"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            app:cornerRadius="18dp"
                            app:icon="@android:drawable/ic_menu_mapmode"
                            app:iconGravity="textStart"
                            app:iconTint="#FFFFFF" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CLIMA ACTUAL (con título dinámico) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_clima"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toBottomOf="@id/card_alerta_helada">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Título dinámico: CIUDAD, PAÍS -->
                        <TextView
                            android:id="@+id/tv_clima_actual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clima Actual"
                            android:textColor="@color/verdeOscuro"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            tools:text="Clima Actual" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_temp_actual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="22°"
                                android:textColor="@color/verdeOscuro"
                                android:textSize="48sp"
                                android:textStyle="bold"
                                tools:text="22°" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">


                                <TextView
                                    android:id="@+id/tv_desc_clima"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Parcialmente nublado"
                                    android:textColor="@color/black"
                                    android:textSize="12sp"
                                    tools:text="Parcialmente nublado" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/pb_clima"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:indeterminateTint="#2E7D32"
                                android:visibility="gone" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <!-- HUMEDAD (de la API) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_water_drop"
                                    app:tint="#2196F3" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="HUMEDAD"
                                    android:textColor="#78909C"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tv_humedad"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="64%"
                                    android:textColor="#1B5E20"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="64%" />
                            </LinearLayout>

                            <!-- LLUVIA (de la API) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_rainy"
                                    app:tint="#FF9800" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="LLUVIA"
                                    android:textColor="#78909C"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tv_lluvia"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="20%"
                                    android:textColor="#1B5E20"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="20%" />
                            </LinearLayout>

                            <!-- VIENTO (de la API) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_air"
                                    app:tint="#9C27B0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="VIENTO"
                                    android:textColor="#78909C"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tv_viento"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12 km/h"
                                    android:textColor="#1B5E20"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    tools:text="12 km/h" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Fuente -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="end"
                            android:text="Fuente: Google Weather"
                            android:textColor="#B0BEC5"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- MI CULTIVO PRINCIPAL -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cultivo_maiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toBottomOf="@id/card_clima">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MI CULTIVO PRINCIPAL"
                            android:textColor="#78909C"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <androidx.cardview.widget.CardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="#E8F5E9"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="10dp"
                                    android:src="@drawable/ic_leaf"
                                    app:tint="@color/verdeClaro" />
                            </androidx.cardview.widget.CardView>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_nombre_lote"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Papa Yungay"
                                    android:textColor="#1B5E20"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="Papa Yungay" />

                                <TextView
                                    android:id="@+id/tv_tipo_cultivo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Sector: El Olivo - Parcela 04"
                                    android:textColor="#78909C"
                                    android:textSize="12sp"
                                    tools:text="Sector: El Olivo - Parcela 04" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Estado de crecimiento"
                                android:textColor="#546E7A"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_progreso_dias"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Día 45 de 120"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="Día 45 de 120" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pb_progreso"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:progress="37"
                            android:progressDrawable="@drawable/custom_progress_green" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_estado"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="● SALUDABLE"
                                android:textColor="#2E7D32"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_progreso_porcentaje"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🕒 PRÓXIMO RIEGO: MAÑANA"
                                android:textColor="#F57F17"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PRECIO MERCADO y TAREAS HOY -->
                <LinearLayout
                    android:id="@+id/layout_precios_tareas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    app:layout_constraintTop_toBottomOf="@id/card_cultivo_maiz">

                    <!-- PRECIO MERCADO -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_precios"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PRECIO MERCADO (KG)"
                                android:textColor="#78909C"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_precio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="S/ 2.45"
                                android:textColor="#1B5E20"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="S/ 2.45" />

                            <TextView
                                android:id="@+id/tv_variacion_precio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="+ S/ 0.15 hoy"
                                android:textColor="#2E7D32"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="+ S/ 0.15 hoy" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- TAREAS HOY -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_recordatorios"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TAREAS HOY"
                                android:textColor="#78909C"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_tareas_hoy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="3"
                                android:textColor="#1B5E20"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                tools:text="3" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pendientes"
                                android:textColor="#1B5E20"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_desc_tareas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Fertilización y Poda"
                                android:textColor="#78909C"
                                android:textSize="11sp"
                                tools:text="Fertilización y Poda" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Espacio adicional (AHORA SÍ FUNCIONA) -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_precios_tareas" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- FAB para Nuevo Cultivo -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btn_nuevo_cultivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:text="Nuevo Cultivo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/verde"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="#FFFFFF"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ============================================================
         BOTTOM NAVIGATION BAR
    ============================================================ -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:elevation="8dp"
            app:itemIconTint="@color/bottom_nav_color_selector"
            app:itemTextColor="@color/bottom_nav_color_selector"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_bottom_nav"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>