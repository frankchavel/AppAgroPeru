<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5F0">

    <!-- ============================================================
         SCROLL PRINCIPAL
    ============================================================ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_dashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================================
                 HEADER VERDE — saludo + clima
            ============================================================ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_green_rounded"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="28dp">

                <!-- Saludo -->
                <TextView
                    android:id="@+id/tv_saludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido 👋"
                    android:textColor="@color/verdeOscuro"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tv_nombre_usuario"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Agricultor"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_saludo"
                    app:layout_constraintEnd_toStartOf="@id/cv_perfil"
                    tools:text="Agricultor"/>

                <!-- Avatar perfil -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_perfil"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardBackgroundColor="#2E7D32"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_saludo"
                    app:layout_constraintBottom_toBottomOf="@id/tv_nombre_usuario">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_eco"
                            app:tint="#FFFFFF"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card blanco semi-transparente: ubicación + clima -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_clima_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/NegroTransparente"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_nombre_usuario"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <!-- Ubicación -->
                        <LinearLayout
                            android:id="@+id/ll_ubicacion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/tv_fecha_clima">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                android:layout_marginEnd="4dp"
                                app:tint="@color/white"/>

                            <TextView
                                android:id="@+id/tv_ubicacion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cusco, Perú"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                tools:text="Cusco, Perú"/>
                        </LinearLayout>

                        <!-- "Hoy" -->
                        <TextView
                            android:id="@+id/tv_fecha_clima"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hoy"
                            android:textColor="#C8E6C9"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <!-- Temperatura grande -->
                        <TextView
                            android:id="@+id/tv_temp_actual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="22°"
                            android:textColor="@color/white"
                            android:textSize="56sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="-4dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/ll_ubicacion"
                            tools:text=" "/>

                        <!-- Descripción clima -->
                        <TextView
                            android:id="@+id/tv_desc_clima"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parcialmente nublado"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_temp_actual"
                            tools:text="Parcialmente nublado"/>

                        <!-- Stats: Humedad / Lluvia / Viento -->
                        <LinearLayout
                            android:id="@+id/ll_stats_clima"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_fecha_clima"
                            app:layout_constraintBottom_toBottomOf="@id/tv_desc_clima">

                            <!-- Humedad -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_water_drop"
                                    app:tint="@color/Celeste"
                                    android:layout_marginEnd="5dp"/>

                                <TextView
                                    android:id="@+id/tv_humedad"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    tools:text=""/>
                            </LinearLayout>

                            <!-- Probabilidad lluvia -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_rainy"
                                    app:tint="@color/Gris"
                                    android:layout_marginEnd="5dp"/>

                                <TextView
                                    android:id="@+id/tv_lluvia"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    tools:text=""/>
                            </LinearLayout>

                            <!-- Viento -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_air"
                                    app:tint="#C8E6C9"
                                    android:layout_marginEnd="5dp"/>

                                <TextView
                                    android:id="@+id/tv_viento"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12 km/h"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    tools:text="12 km/h"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Loading clima -->
                        <ProgressBar
                            android:id="@+id/pb_clima"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:visibility="gone"
                            android:indeterminateTint="#C8E6C9"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ============================================================
                 CUERPO: padding lateral
            ============================================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">
                <!-- ============================================================
     PRONÓSTICO 4 DÍAS
============================================================ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pronóstico de Lluvias (4 días)"
                    android:textColor="#1B2A1E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_pronostico_lluvia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

                <!-- ============================================================
                     ALERTAS CLIMÁTICAS
                ============================================================ -->

                <!-- Alerta 1: Helada — amarillo/naranja -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_alerta_helada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="visible"
                    app:cardBackgroundColor="#FFFDE7"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FFE082"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:layout_marginEnd="10dp"
                            app:tint="#F57F17"/>

                        <TextView
                            android:id="@+id/tv_alerta_helada"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Riesgo de helada esta noche"
                            android:textColor="#E65100"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Riesgo de helada esta noche"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#F57F17"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Alerta 2: Lluvias — azul -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_alerta_lluvia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:visibility="visible"
                    app:cardBackgroundColor="#E3F2FD"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#90CAF9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_rainy"
                            android:layout_marginEnd="10dp"
                            app:tint="#1565C0"/>

                        <TextView
                            android:id="@+id/tv_alerta_lluvia"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Lluvias intensas mañana"
                            android:textColor="#1565C0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Lluvias intensas mañana"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#1565C0"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ============================================================
                     ACCIONES RÁPIDAS
                ============================================================ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acciones Rápidas"
                    android:textColor="#1B2A1E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <!-- Nuevo Cultivo -->
                    <LinearLayout
                        android:id="@+id/btn_nuevo_cultivo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="6dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="@color/verdeClaro"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@android:drawable/ic_input_add"
                                    app:tint="#FFFFFF"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nuevo Cultivo"
                            android:textColor="#1B2A1E"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Ver Mapa -->
                    <LinearLayout
                        android:id="@+id/btn_ver_mapa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginHorizontal="6dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="@color/Azul"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@android:drawable/ic_menu_mapmode"
                                    app:tint="#FFFFFF"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ver Mapa"
                            android:textColor="#1B2A1E"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Recordatorios -->
                    <LinearLayout
                        android:id="@+id/btn_recordatorios"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginHorizontal="6dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="@color/yellow"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@android:drawable/ic_popup_reminder"
                                    app:tint="#FFFFFF"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recordatorios"
                            android:textColor="#1B2A1E"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Precios -->
                    <LinearLayout
                        android:id="@+id/btn_precios"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="6dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="@color/Red"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:src="@drawable/ic_trending_up"
                                    app:tint="#FFFFFF"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Precios"
                            android:textColor="#1B2A1E"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- ============================================================
                     MIS CULTIVOS
                ============================================================ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mis Cultivos"
                        android:textColor="#1B2A1E"
                        android:textSize="16sp"
                        android:textStyle="bold"/>




                </LinearLayout>
                <!-- ============================================================
                     LISTA DE CULTIVOS
                ============================================================ -->
                <!-- RecyclerView para cargar dinámicamente desde BD -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cultivos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_cultivo_dashboard"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <!-- ============================================================
         BOTTOM NAVIGATION BAR
    ============================================================ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:itemIconTint="@color/bottom_nav_color_selector"
        app:itemTextColor="@color/bottom_nav_color_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>