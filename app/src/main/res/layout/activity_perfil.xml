<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PerfilActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_inferior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/header_container"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="@drawable/bg_profile_header"
                android:padding="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_titulo_perfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Perfil"
                    android:textColor="#0C1324"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/ic_notificaciones"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_border_icon"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="#78909C"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/photo_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="8dp"
                app:layout_constraintBottom_toBottomOf="@id/header_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/header_container">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_perfil_grande"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person_outline"
                    android:background="#E0E0E0"
                    app:cornerFamily="rounded"
                    app:cornerSize="50%"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageView
                    android:id="@+id/btn_editar_foto"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_border_icon"
                    android:elevation="4dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#053C0B"
                    app:layout_constraintBottom_toBottomOf="@id/iv_perfil_grande"
                    app:layout_constraintEnd_toEndOf="@id/iv_perfil_grande"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_nombre_usuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Carlos Flores Ramirez"
                android:textColor="#0C1324"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/photo_container" />

            <TextView
                android:id="@+id/tv_miembro_desde"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Miembro desde Noviembre 2023"
                android:textColor="#78909C"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_nombre_usuario" />

            <TextView
                android:id="@+id/lbl_info_personal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="INFORMACIÓN PERSONAL"
                android:textColor="#546E7A"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_miembro_desde" />

            <LinearLayout
                android:id="@+id/container_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_options"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/lbl_info_personal">

                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                    <ImageView android:id="@+id/ic_mail_perfil" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_dialog_email" app:tint="#78909C" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <TextView android:id="@+id/tv_perfil_correo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="carlos.flores@agroperu.com" android:textColor="#0C1324" android:textSize="14sp" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/ic_mail_perfil" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginVertical="6dp"/>

                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                    <ImageView android:id="@+id/ic_cel_perfil" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_call" app:tint="#78909C" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <TextView android:id="@+id/tv_perfil_celular" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+51 987 654 321" android:textColor="#0C1324" android:textSize="14sp" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/ic_cel_perfil" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/lbl_opciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="AJUSTES Y OPCIONES"
                android:textColor="#546E7A"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/container_info" />

            <LinearLayout
                android:id="@+id/container_opciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_profile_options"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/lbl_opciones">

                <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/btn_editar_perfil_opcion" android:layout_width="match_parent" android:layout_height="48dp" android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/ic_option_edit" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_border_icon" android:padding="8dp" android:src="@android:drawable/ic_menu_edit" app:tint="#78909C" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Editar Perfil" android:textColor="#0C1324" android:textStyle="bold" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/ic_option_edit" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" android:rotation="-90" app:tint="#B0BEC5" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginVertical="4dp"/>

                <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/btn_ubicacion_opcion" android:layout_width="match_parent" android:layout_height="48dp" android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/ic_option_loc" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_border_icon" android:padding="8dp" android:src="@android:drawable/ic_menu_mylocation" app:tint="#39FF14" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ubicación de Finca" android:textColor="#0C1324" android:textStyle="bold" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/ic_option_loc" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <TextView android:id="@+id/tv_perfil_ubicacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cajamarca, Perú" android:textColor="#78909C" android:textSize="12sp" android:layout_marginEnd="8dp" app:layout_constraintEnd_toStartOf="@id/ic_arrow_loc" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    <ImageView android:id="@+id/ic_arrow_loc" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" android:rotation="-90" app:tint="#B0BEC5" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cerrar_sesion"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="40dp"
                android:text="Cerrar Sesión"
                android:textColor="#39FF14"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="#39FF14"
                app:iconGravity="textStart"
                app:strokeColor="#39FF14"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/container_opciones" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/nav_inferior"
        layout="@layout/layout_nav_inferior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>